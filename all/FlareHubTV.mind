{"root":{"data":{"id":"di197v71ns00","created":1777020568271,"text":"FlareTVBrowser&FlareHubTV落地策略"},"children":[{"data":{"id":"di198nmyemg0","created":1777020630183,"text":"FlareHubTV","layout_mind_offset":{"x":-41.33333271741873,"y":0.6666666567325592},"layout_right_offset":{"x":-9.999999850988388,"y":-82.66666543483734}},"children":[{"data":{"id":"di198rrzcrs0","created":1777020639194,"text":"产品落地"},"children":[{"data":{"id":"di198v9mec00","created":1777020646791,"text":"厂商将原来YouTube 应用屏蔽，用户点击YouTube Icon，倒流到FlareHubTV"},"children":[]},{"data":{"id":"di199kr9axs0","created":1777020702277,"text":"FlareHubTV包括功能：Web YouTube，海报，广告变现"},"children":[]}]},{"data":{"id":"di19ai46m5c0","created":1777020774893,"text":"商务模式"},"children":[{"data":{"id":"di19cicczb40","created":1777020932115,"text":"厂商提供预付NRE费用，再从变现收入中进行返还"},"children":[]},{"data":{"id":"di19d0skr540","created":1777020972278,"text":"变现收入达到指定收入前，不进行分成（目的：厂商铺量要达到一定数量级，鼓励厂商多铺量）"},"children":[]}]},{"data":{"id":"di19e6htq200","created":1777021063053,"text":"后台要求"},"children":[{"data":{"id":"di19ee9u2zc0","created":1777021079984,"text":"保留渠道号，用于各个不同厂商统计收入和数据收集"},"children":[]}]},{"data":{"id":"di19eqxces80","created":1777021107527,"text":"LMS要求"},"children":[{"data":{"id":"di19eujcbao0","created":1777021115387,"text":"保留LMS商务和产品水印（能细化控制YouTube，Netflix），不需要厂商报备MAC"},"children":[]},{"data":{"id":"di19nxycp880","created":1777021828103,"text":"厂商需申请证书，否则拿到产品和其他家证书，会因信息不匹配而弹水印"},"children":[]}]},{"data":{"id":"di19szup7vk0","created":1777022224056,"text":"Google Play上架","layout_right_offset":{"x":-3.9999999403953552,"y":46.6666659712792}},"children":[{"data":{"id":"di19t8767140","created":1777022242225,"text":"上架GP版本有单独的渠道号"},"children":[]},{"data":{"id":"di19tkzedsw0","created":1777022270053,"text":"上架GP时，为避免审核问题，YouTube形态可能是外链（参考JustWatch）"},"children":[]},{"data":{"id":"di19u95n5080","created":1777022322673,"text":"注意：FlareHubTV是2B产品，不是2C产品"},"children":[]}]},{"data":{"id":"di19vedtmeg0","created":1777022412416,"text":"Branch topics"},"children":[]}]},{"data":{"id":"di19pzyf13k0","created":1777021989189,"text":"Flare TV Browser","layout_right_offset":{"x":34.666666150092965,"y":57.99999913573262}},"children":[{"data":{"id":"di19rpat7bc0","created":1777022122722,"text":"LMS要求","expandState":"expand"},"children":[{"data":{"id":"di19qqoq5gg0","created":1777022047376,"text":"Netflix（或是其他Top App）：同YouTube"},"children":[]},{"data":{"id":"di19qc1vcy00","created":1777022015519,"text":"YouTube：植入LMS，进行MAC地址报备"},"children":[]}]},{"data":{"id":"di19rzmlfio0","created":1777022145202,"text":"商务模式"},"children":[{"data":{"id":"di19s2l8fig0","created":1777022151650,"text":"按Royalty收费"},"children":[]}]},{"data":{"id":"di19s9rtsao0","created":1777022167286,"text":"产品落地策略"},"children":[{"data":{"id":"di19sf548800","created":1777022178974,"text":"以Flare TV Browser当前的版本提供给厂商客户"},"children":[]}]}]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}