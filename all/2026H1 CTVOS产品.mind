ser"},"children":[]},{"data":{"id":"djehjl7obkw0","created":1782020493668,"text":"落地项目：长安马自达"},"children":[]}]},{"data":{"id":"djeg832001k0","created":1782016771027,"text":"Native App"},"children":[{"data":{"id":"djehildmaps0","created":1782020415663,"text":"特性：自身+其他供应商授权API为主机厂做定制化开发"},"children":[]},{"data":{"id":"djehjdrsi1s0","created":1782020477470,"text":"落地项目：东风日产AccuWeather"},"children":[]},{"data":{"id":"djehpdn745c0","created":1782020947377,"text":"潜在机会：奇瑞捷途"},"children":[]}]}]}]},{"data":{"id":"djeg73rv04o0","created":1782016694226,"text":"下半年产品规划：聚焦流量产品，提升用户使用时长","layout_mind_offset":{"x":990.0000227292413,"y":455.0000256361802},"layout_right_offset":{"x":-159.00000050332847,"y":69.00000504211198},"expandState":"expand"},"children":[{"data":{"id":"djeiylh3zxs0","created":1782024490811,"text":"Flare OS 智能生态","expandState":"expand"},"children":[{"data":{"id":"djehuo3qom80","created":1782021361966,"text":"FlareHub TV版本迭代","expandState":"expand"},"children":[{"data":{"id":"djehv26c3i80","created":1782021392598,"text":"v1.0基础特性（已release）：Web YouTube + Google Analytics"},"children":[]},{"data":{"id":"djehvc3hfww0","created":1782021414193,"text":"v2.0新增特性（已release）","expandState":"expand"},"children":[{"data":{"id":"djehzzv4cpc0","created":1782021779387,"text":" 分类内容（Sports+Live+Drama Shorts）"},"children":[]},{"data":{"id":"djehztga1lc0","created":1782021765429,"text":"聚合后台"},"children":[{"data":{"id":"djei1hor8oo0","created":1782021896548,"text":"内容动态运营维度：根据厂商、区域、内存大小"},"children":[]},{"data":{"id":"djei1neupso0","created":1782021909010,"text":"广告开关控制维度：根据内容源、内存大小、厂商"},"children":[]}]}]},{"data":{"id":"djehw2ko4qo0","created":1782021471829,"text":"v2.1.1新增特性（已release）： DAZN + 推荐区域多语言支持"},"children":[]},{"data":{"id":"djeia9v9g8g0","created":1782022584805,"text":"v2.2新增特性：Home拦截+后台UI优化+YouTube Pad版+Netflix"},"children":[]},{"data":{"id":"djeip4dsg0g0","created":1782023748327,"text":"基于聚合上线后GA分析，拟增加","expandState":"expand"},"children":[{"data":{"id":"djeim4i7xfs0","created":1782023513502,"text":"优质内容聚合"},"children":[{"data":{"id":"djeimktd5o80","created":1782023549005,"text":"聚合其他Top优质+本地Premium合法合规内容","layout_right_offset":{"x":87.99993896484398,"y":0}},"children":[]}]},{"data":{"id":"djeiqidphh40","created":1782023857161,"text":"画中画（PiP）多任务流"},"children":[{"data":{"id":"djeiqudads80","created":1782023883257,"text":"允许用户在观看 YouTube 主视频的同时，常驻侧边栏浏览FAST频道、体育赛事比分或短剧，拉长设备开机时长。"},"children":[]},{"data":{"id":"djeir7sq3s00","created":1782023912489,"text":"允许用户在观看 YouTube 主视频的同时，常驻侧边栏展示广告"},"children":[]}]},{"data":{"id":"djeiqrrgwgw0","created":1782023877584,"text":"AI搜索"},"children":[{"data":{"id":"djeisi2p6o80","created":1782024013224,"text":"一键打通 YouTube 视频、FAST 电视节目与短剧内容，降低用户内容获取成本。"},"children":[]}]},{"data":{"id":"djeitl37bxs0","created":1782024098149,"text":"轻量化轻量级覆盖"},"children":[{"data":{"id":"djeitvsiu5k0","created":1782024121448,"text":"针对低标配低成本机顶盒，深度优化 Web 渲染性能，确保多模块叠加时系统不卡顿。"},"children":[]}]},{"data":{"id":"djeiueslu6w0","created":1782024162811,"text":"高变现内容板块深度运营"},"children":[{"data":{"id":"djeix4pc09k0","created":1782024375938,"text":"在赛事直播或YouTube体育视频旁，实时叠加比分看板、球员数据。未来可探讨与海外合规体育竞猜或衍生品电商联动。","layout_right_offset":{"x":-0.9999999478459358,"y":0}},"children":[]}]}]}]},{"data":{"id":"djeizjn34lk0","created":1782024565182,"text":"Flare云游戏中心"},"children":[{"data":{"id":"djej062zuwg0","created":1782024614034,"text":"厂商价值：无需升级高昂的CPU/GPU硬件，即可让低端电视/投影仪具备运行3A大作或轻度休闲游戏的能力"},"children":[]},{"data":{"id":"djej0nozxzc0","created":1782024652369,"text":"用户价值：只需连接蓝牙手柄或手机充当虚拟手柄，即可免下载、点开即玩海量云游戏。"},"children":[]},{"data":{"id":"djej11rzdjs0","created":1782024683025,"text":"商业模式：与云游戏平台进行时长分成；在游戏加载界面、转场期间植入高价值互动视频广告。"},"children":[]}]},{"data":{"id":"djeizqbyvi80","created":1782024579748,"text":"Flare氛围广告系统"},"children":[{"data":{"id":"djej1gjjzog0","created":1782024715167,"text":"厂商价值：将用户未关闭电视、不看内容时的“闲置/待机时间”转化为纯利润。"},"children":[]},{"data":{"id":"djej1pxcqlc0","created":1782024735592,"text":"用户价值：提供高精度的4K动态风景、壁画、时钟、实时天气及个性化本地新闻流，提升家居美感。"},"children":[]},{"data":{"id":"djej20kv4qo0","created":1782024758782,"text":"商业模式：在屏保角落、背景中融入非侵入式的品牌壁纸广告、本地生活消费优惠券提示。"},"children":[]}]},{"data":{"id":"djeizwurxw80","created":1782024593946,"text":"Flare屏前零售大屏"},"children":[{"data":{"id":"djej2qmbvmw0","created":1782024815467,"text":"厂商价值：将电视大屏转变为家庭离线消费的入口。"},"children":[]},{"data":{"id":"djej2xta9pc0","created":1782024831125,"text":"用户价值：观看特定内容（如美食、体育、电影）时，屏幕边缘弹出相关周边或外卖服务的二维码，扫码即买。"},"children":[]},{"data":{"id":"djej34basrs0","created":1782024845275,"text":"商业模式：通过电商导流抽取CPS（按销售分成）佣金，以及品牌商品的展示坑位费。"},"children":[]}]}]}]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}